<script>
// ════════════════════════════════════════════════════════
//  ZXing-js QR / 2D barcode scanner
//  Kirjasto: @zxing/library
//  Tuetut formaatit: QR Code, Data Matrix, Aztec, PDF417,
//  Code128, Code39, EAN-13/8, UPC, ITF, RSS ja muut
// ════════════════════════════════════════════════════════

var currentUser   = null;
var currentAction = null;
var serialSet     = new Set();
var liveReader    = null;   // ZXing BrowserMultiFormatReader instance
var liveActive    = false;
var psStream      = null;
var psActive      = false;
var psReader      = null;   // ZXing for point&shoot decode
var toastTimer    = null;
var lastScanned   = '';
var lastScannedAt = 0;

var CFG = {
  romutus: {
    label:'Romutus', badgeCls:'badge-romutus', submitCls:'romutus',
    icon:'\uD83D\uDDD1\uFE0F', submitLabel:'Romuta mittarit',
    successTitle:'Romutus kirjattu!',
    successSub:'Mittarit on kirjattu romutukseen. Tiedot on v\u00e4litetty j\u00e4rjestelm\u00e4\u00e4n.'
  },
  huolto: {
    label:'Huolto', badgeCls:'badge-huolto', submitCls:'huolto',
    icon:'\uD83D\uDD27', submitLabel:'L\u00e4het\u00e4 huoltoon',
    successTitle:'Huoltol\u00e4hetys kirjattu!',
    successSub:'Mittareiden huoltol\u00e4hetys on kirjattu j\u00e4rjestelm\u00e4\u00e4n.'
  },
  varasto: {
    label:'Varasto', badgeCls:'badge-varasto', submitCls:'varasto',
    icon:'\uD83D\uDCE6', submitLabel:'Vie varastoon',
    successTitle:'Varastokirjaus tehty!',
    successSub:'Mittarit on kirjattu varastoon uudelleenk\u00e4ytt\u00f6\u00e4 varten.'
  }
};

// ══ NAV ══
window.showScreen = function(id) {
  document.querySelectorAll('.screen').forEach(function(s){ s.classList.remove('active'); });
  document.getElementById('screen-'+id).classList.add('active');
  document.getElementById('topbar').style.display = (id==='login') ? 'none' : 'flex';
  if (id !== 'form') { stopLiveScan(); stopPointShoot(); }
};

// ══ LOGIN ══
window.doLogin = function() {
  showLoading('Kirjaudutaan sis\u00e4\u00e4n\u2026');
  setTimeout(function(){
    currentUser = { name:'Antti Jokinen', initials:'AJ' };
    document.getElementById('user-avatar').textContent = 'AJ';
    document.getElementById('user-name').textContent   = 'A. Jokinen';
    hideLoading();
    window.showScreen('select');
    showToast('Kirjauduttu sis\u00e4\u00e4n \u2713','ok');
  }, 1300);
};

window.logout = function() {
  stopLiveScan(); stopPointShoot();
  currentUser = null; currentAction = null; serialSet.clear();
  window.showScreen('login');
};

// ══ SELECT ══
window.selectAction = function(action) {
  currentAction = action;
  var c = CFG[action];
  document.getElementById('form-page-title').textContent = c.label;
  var badge = document.getElementById('form-badge');
  badge.textContent = c.icon + '  ' + c.label;
  badge.className   = 'form-badge ' + c.badgeCls;
  var btn = document.getElementById('submit-btn');
  btn.className = 'submit-btn ' + c.submitCls;
  document.getElementById('submit-icon').textContent  = c.icon;
  document.getElementById('submit-label').textContent = c.submitLabel;
  serialSet.clear();
  document.getElementById('manual-input').value = '';
  document.getElementById('notes-input').value  = '';
  clearScanUI();
  renderChips(); updateSubmitBtn();
  window.showScreen('form');
};

window.goBack = function() { stopLiveScan(); window.showScreen('select'); };

// ══ SERIALS ══
function addSerial(raw) {
  var val = raw.trim();
  if (!val || val.length < 3) return false;
  if (serialSet.has(val)) { showToast('Jo listalla: '+val,'err'); return false; }
  serialSet.add(val); renderChips(); updateSubmitBtn();
  return true;
}
window.removeSerial = function(s) { serialSet.delete(s); renderChips(); updateSubmitBtn(); };

function renderChips() {
  var wrap=document.getElementById('chips-wrap'), empty=document.getElementById('chips-empty');
  document.getElementById('serial-count').textContent = serialSet.size;
  if (serialSet.size===0){ wrap.style.display='none'; empty.style.display='block'; return; }
  empty.style.display='none'; wrap.style.display='flex';
  wrap.innerHTML='';
  serialSet.forEach(function(s){
    var d=document.createElement('div'); d.className='chip';
    d.innerHTML=s+'<button class="chip-x" onclick="removeSerial(\''+s+'\')">\u00d7</button>';
    wrap.appendChild(d);
  });
}
function updateSubmitBtn(){ document.getElementById('submit-btn').disabled=(serialSet.size===0); }

window.addManual = function(){
  var inp=document.getElementById('manual-input');
  if(addSerial(inp.value)){ inp.value=''; inp.focus(); }
};
window.manualKeydown = function(e){ if(e.key==='Enter'){ e.preventDefault(); window.addManual(); } };

// ══ ZXing LIVE SCAN ══
// ZXing BrowserMultiFormatReader supports:
// QR_CODE, DATA_MATRIX, AZTEC, PDF_417,
// CODE_128, CODE_39, CODE_93, EAN_13, EAN_8,
// UPC_A, UPC_E, ITF, RSS_14, RSS_EXPANDED
window.toggleLiveScan = function(){ liveActive ? stopLiveScan() : startLiveScan(); };

function startLiveScan() {
  clearScanUI();
  setScanLoading(true);

  // Check ZXing loaded
  if (typeof ZXing === 'undefined') {
    setScanLoading(false);
    showScanError('ZXing-kirjasto ei latautunut. Tarkista verkkoyhteys.');
    return;
  }

  try {
    liveReader = new ZXing.BrowserMultiFormatReader();
  } catch(e) {
    setScanLoading(false);
    showScanError('Kirjaston alustus ep\u00e4onnistui: ' + e.message);
    return;
  }

  // Show viewport, update button
  document.getElementById('cam-viewport').classList.add('open');
  document.getElementById('scan-toggle-btn').classList.add('active');
  document.getElementById('scan-btn-icon').textContent  = '\u23f9';
  document.getElementById('scan-btn-label').textContent = 'Lopeta skannaus';

  // Start decoding from video device
  // null deviceId = let ZXing pick the best camera (prefers back camera)
  liveReader.decodeFromVideoDevice(null, 'cam-video', function(result, err) {
    setScanLoading(false);
    if (result) {
      var text = result.getText();
      var now  = Date.now();
      // Debounce: ignore same code for 2.5s
      if (text === lastScanned && (now - lastScannedAt) < 2500) return;
      lastScanned = text; lastScannedAt = now;
      onCodeFound(text, 'live');
    }
    // err here is just "no barcode found this frame" — not a real error
  });

  liveActive = true;
}

function stopLiveScan() {
  if (liveReader) {
    try { liveReader.reset(); } catch(e){}
    liveReader = null;
  }
  liveActive = false;
  document.getElementById('cam-viewport').classList.remove('open');
  document.getElementById('scan-toggle-btn').classList.remove('active');
  document.getElementById('scan-btn-icon').textContent  = '\uD83D\uDCF7';
  document.getElementById('scan-btn-label').textContent = 'Skannaa QR-koodilla';
  setScanLoading(false);
  lastScanned = '';
}

// ══ POINT & SHOOT ══
window.togglePointShoot = function(){ psActive ? stopPointShoot() : startPointShoot(); };

function startPointShoot() {
  setPsResult('','');
  if (!navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
    setPsResult('err','\u26a0 Kamera ei ole tuettu t\u00e4ll\u00e4 selaimella.'); return;
  }
  navigator.mediaDevices.getUserMedia({
    video: { facingMode:'environment', width:{ideal:1280}, height:{ideal:720} }
  }).then(function(stream){
    psStream = stream;
    var video = document.getElementById('ps-video');
    video.srcObject = stream; video.play();
    document.getElementById('ps-preview-wrap').classList.add('open');
    document.getElementById('ps-capture-btn').disabled = false;
    document.getElementById('ps-open-btn').classList.add('active');
    document.getElementById('ps-open-icon').textContent  = '\u23f9';
    document.getElementById('ps-open-label').textContent = 'Sulje kamera';
    psActive = true;
  }).catch(function(err){
    var msg = 'Kameran avaaminen ep\u00e4onnistui.';
    if (err.name==='NotAllowedError') msg='Kameran k\u00e4ytt\u00f6oikeus ev\u00e4tty.';
    else if (err.name==='NotFoundError') msg='Kameraa ei l\u00f6ydy.';
    setPsResult('err','\u26a0 '+msg);
  });
}

function stopPointShoot() {
  if (psStream){ psStream.getTracks().forEach(function(t){ t.stop(); }); psStream=null; }
  var video=document.getElementById('ps-video'); if(video) video.srcObject=null;
  document.getElementById('ps-preview-wrap').classList.remove('open');
  document.getElementById('ps-capture-btn').disabled = true;
  document.getElementById('ps-open-btn').classList.remove('active');
  document.getElementById('ps-open-icon').textContent  = '\uD83C\uDFAF';
  document.getElementById('ps-open-label').textContent = 'Avaa point & shoot';
  psActive = false;
}

window.captureFrame = function() {
  var video = document.getElementById('ps-video');
  if (!video || !psStream) return;

  // Flash
  var flash=document.getElementById('ps-flash');
  flash.style.opacity='0.45'; setTimeout(function(){ flash.style.opacity='0'; },110);
  if(navigator.vibrate) navigator.vibrate(30);
  setPsResult('processing','\u21bb Luetaan\u2026');

  // Draw frame to canvas → blob URL → ZXing decodeFromImageUrl
  var canvas = document.getElementById('ps-canvas');
  canvas.width  = video.videoWidth  || 1280;
  canvas.height = video.videoHeight || 720;
  canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);

  var dataUrl = canvas.toDataURL('image/jpeg', 0.92);

  if (typeof ZXing === 'undefined') {
    setPsResult('err','\u26a0 ZXing-kirjasto ei saatavilla.'); return;
  }

  var reader = new ZXing.BrowserMultiFormatReader();
  reader.decodeFromImageUrl(dataUrl).then(function(result){
    onCodeFound(result.getText(), 'ps');
  }).catch(function(){
    setPsResult('err','\u26a0 Ei tunnistettu. Kohdista koodi kehykseen ja yrit\u00e4 uudelleen.');
    if(navigator.vibrate) navigator.vibrate([30,20,30]);
  });
};

// ══ CODE FOUND (shared) ══
function onCodeFound(text, source) {
  var cleaned = text.trim();
  if (!cleaned || cleaned.length < 3) {
    if (source==='ps') setPsResult('err','\u26a0 Liian lyhyt arvo: "'+text+'"');
    else showScanResult('err','\u26a0 Liian lyhyt arvo: "'+text+'"');
    return;
  }
  // Flash live cam
  if (source==='live') {
    var f=document.getElementById('cam-flash');
    if(f){ f.style.opacity='0.3'; setTimeout(function(){ f.style.opacity='0'; },150); }
  }
  var added = addSerial(cleaned);
  if (added) {
    if (source==='ps') setPsResult('ok','\u2713 Luettu: '+cleaned);
    else showScanResult('ok','\u2713 Luettu: '+cleaned);
    showToast('\u2713 '+cleaned,'ok');
    if(navigator.vibrate) navigator.vibrate(70);
  }
}

// ══ SCAN UI HELPERS ══
function clearScanUI() {
  setScanLoading(false);
  hideScanResult(); hideScanError();
  setPsResult('','');
}
function setScanLoading(on) {
  document.getElementById('scan-loading').className = 'scan-status loading' + (on?' show':'');
}
function showScanResult(type, msg) {
  document.getElementById('scan-ok').className  = 'scan-status ok'  + (type==='ok'  ?' show':'');
  document.getElementById('scan-err').className = 'scan-status err' + (type==='err' ?' show':'');
  if (type==='ok')  document.getElementById('scan-ok').textContent  = msg;
  if (type==='err') document.getElementById('scan-err').textContent = msg;
}
function hideScanResult() {
  document.getElementById('scan-ok').className  = 'scan-status ok';
  document.getElementById('scan-err').className = 'scan-status err';
}
function showScanError(msg) {
  var el=document.getElementById('scan-error-banner');
  el.textContent='\u26a0 '+msg; el.classList.add('show');
}
function hideScanError() {
  document.getElementById('scan-error-banner').classList.remove('show');
}
function setPsResult(type, msg) {
  var el=document.getElementById('ps-result');
  el.textContent=msg; el.className=type?('ps-result '+type):'ps-result';
}

// ══ SUBMIT ══
window.submitForm = function() {
  if (serialSet.size===0) return;
  stopLiveScan(); stopPointShoot();
  var c=CFG[currentAction];
  showLoading('L\u00e4hetet\u00e4\u00e4n '+serialSet.size+' mittaria\u2026');
  setTimeout(function(){
    hideLoading();
    var circ=document.getElementById('success-circle');
    circ.textContent=c.icon; circ.className='success-circle '+currentAction;
    document.getElementById('success-title').textContent=c.successTitle;
    document.getElementById('success-sub').textContent  =c.successSub;
    var now=new Date();
    var ts=now.toLocaleDateString('fi-FI')+' '+now.toLocaleTimeString('fi-FI',{hour:'2-digit',minute:'2-digit'});
    var ref='REF-'+Math.floor(Math.random()*90000+10000);
    document.getElementById('success-meta').innerHTML=
      '<div class="meta-row"><span class="meta-k">Asentaja</span><span class="meta-v">'+currentUser.name+'</span></div>'+
      '<div class="meta-row"><span class="meta-k">Toiminto</span><span class="meta-v">'+c.label+'</span></div>'+
      '<div class="meta-row"><span class="meta-k">Mittareita</span><span class="meta-v">'+serialSet.size+' kpl</span></div>'+
      '<div class="meta-row"><span class="meta-k">Aikaleima</span><span class="meta-v">'+ts+'</span></div>'+
      '<div class="meta-row"><span class="meta-k">Viite</span><span class="meta-v">'+ref+'</span></div>';
    window.showScreen('success');
  },1400);
};

window.newAction = function() { serialSet.clear(); window.showScreen('select'); };

function showLoading(msg){ document.getElementById('loading-txt').textContent=msg; document.getElementById('loading-overlay').classList.add('on'); }
function hideLoading(){ document.getElementById('loading-overlay').classList.remove('on'); }
function showToast(msg,type){
  var t=document.getElementById('toast');
  t.textContent=msg; t.className='toast show'+(type?' '+type:'');
  clearTimeout(toastTimer); toastTimer=setTimeout(function(){ t.className='toast'; },2800);
}

document.addEventListener('visibilitychange',function(){
  if(document.hidden){ stopLiveScan(); stopPointShoot(); }
});
</script>
