<!DOCTYPE html>
<html lang="fi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="default">
<title>Mittarihallinta QR – Vantaan Energia Sähköverkot</title>
<!-- ZXing-js: luotettava QR + useiden formaattien lukija -->
<script src="https://cdn.jsdelivr.net/npm/@zxing/library@0.21.3/umd/index.min.js"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Source+Sans+3:wght@300;400;500;600;700&family=Source+Code+Pro:wght@400;500&display=swap');

:root {
  --ves-navy:   #002D6E;
  --ves-blue:   #0055B8;
  --ves-light:  #E8F0FA;
  --ves-accent: #00AEEF;
  --ves-white:  #FFFFFF;
  --ves-line:   #D0DCF0;
  --ves-text:   #1A1A2E;
  --ves-muted:  #5B6F8C;
  --ves-dim:    #8899BB;
  --red:        #C8002D;
  --amber:      #E07B00;
  --green:      #1A7F45;
  --red-bg:     #FFF0F2;
  --amber-bg:   #FFF8EC;
  --green-bg:   #EDF7F2;
  --sans:  'Source Sans 3', 'Helvetica Neue', Arial, sans-serif;
  --mono:  'Source Code Pro', monospace;
  --safe-top:    env(safe-area-inset-top,    0px);
  --safe-bottom: env(safe-area-inset-bottom, 0px);
  --tap:    52px;
  --radius: 6px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html, body { height: 100%; overflow: hidden; }
body {
  background: var(--ves-light); color: var(--ves-text);
  font-family: var(--sans); font-size: 15px;
  display: flex; flex-direction: column;
  -webkit-tap-highlight-color: transparent;
  overscroll-behavior: none;
}

.screen { display: none; flex: 1; flex-direction: column; overflow: hidden; }
.screen.active { display: flex; }

@keyframes fadeUp  { from{opacity:0;transform:translateY(14px)} to{opacity:1;transform:translateY(0)} }
@keyframes blink   { 0%,100%{opacity:1} 50%{opacity:0.3} }
@keyframes spin    { to{transform:rotate(360deg)} }
@keyframes chipIn  { from{opacity:0;transform:scale(0.85)} to{opacity:1;transform:scale(1)} }
@keyframes scanQR  {
  0%  { top:4px;  opacity:0; } 8%{opacity:1} 92%{opacity:1} 100%{ top:calc(100% - 4px); opacity:0; }
}

/* ── TOPBAR ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 16px; padding-top: var(--safe-top);
  height: calc(56px + var(--safe-top));
  background: var(--ves-navy); flex-shrink: 0; z-index: 50;
}
.topbar-logo { display: flex; align-items: center; gap: 10px; }
.topbar-right { display: flex; align-items: center; gap: 10px; }
.avatar {
  width: 32px; height: 32px; border-radius: 4px;
  background: var(--ves-accent); color: var(--ves-navy);
  display: flex; align-items: center; justify-content: center;
  font-family: var(--mono); font-size: 11px; font-weight: 500;
}
.topbar-username { font-size: 13px; color: rgba(255,255,255,0.75); }
.logout-btn {
  height: 30px; padding: 0 12px;
  border: 1px solid rgba(255,255,255,0.25); border-radius: 4px;
  background: transparent; color: rgba(255,255,255,0.7);
  font-size: 12px; font-family: var(--sans); cursor: pointer;
}
.logout-btn:active { background: rgba(255,255,255,0.1); color:#fff; }

/* ── PAGE HEADER ── */
.page-header { background: var(--ves-navy); padding: 0 16px 18px; flex-shrink: 0; }
.page-header h1 { font-size: 19px; font-weight: 600; color: #fff; margin-bottom: 2px; }
.page-header p  { font-size: 13px; color: rgba(255,255,255,0.6); }

/* ── LOGIN ── */
#screen-login {
  align-items: center; justify-content: center;
  background: var(--ves-navy); padding: 24px;
}
.login-card {
  width: 100%; max-width: 360px;
  background: #fff; border-radius: 8px; overflow: hidden;
  animation: fadeUp 0.4s ease both;
  box-shadow: 0 8px 32px rgba(0,45,110,0.25);
}
.login-card-top { background: var(--ves-navy); padding: 32px 28px 28px; text-align: center; }
.login-logo-svg { width: 180px; height: auto; }
.login-tagline  { font-size: 13px; color: rgba(255,255,255,0.65); line-height: 1.5; margin-top: 8px; }
.login-card-body { padding: 28px; }
.login-body-title { font-size: 16px; font-weight: 600; color: var(--ves-navy); margin-bottom: 6px; }
.login-body-sub   { font-size: 13px; color: var(--ves-muted); margin-bottom: 20px; line-height: 1.5; }
.ms-btn {
  width: 100%; height: var(--tap);
  border: none; border-radius: var(--radius);
  background: var(--ves-blue); color: #fff;
  font-size: 15px; font-weight: 600; font-family: var(--sans);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 10px;
}
.ms-btn:active { background: var(--ves-navy); transform: scale(0.99); }
.ms-icon { width: 20px; height: 20px; display: grid; grid-template-columns:1fr 1fr; gap: 2px; flex-shrink:0; }
.ms-icon span { border-radius: 1px; }
.ms-icon span:nth-child(1){background:#f25022}
.ms-icon span:nth-child(2){background:#7fba00}
.ms-icon span:nth-child(3){background:#00a4ef}
.ms-icon span:nth-child(4){background:#ffb900}
.login-hint { margin-top: 14px; font-size: 11px; color: var(--ves-dim); text-align: center; font-family: var(--mono); }

/* ── SELECT ── */
#screen-select { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.select-scroll {
  padding: 16px 16px calc(16px + var(--safe-bottom));
  display: flex; flex-direction: column; gap: 10px;
  max-width: 560px; margin: 0 auto; width: 100%;
}
.action-card {
  background: #fff; border: 1px solid var(--ves-line);
  border-radius: var(--radius); padding: 18px 16px;
  cursor: pointer;
  display: flex; align-items: center; gap: 14px; min-height: 78px;
  position: relative; overflow: hidden;
}
.action-card::before {
  content: ''; position: absolute;
  left: 0; top: 0; bottom: 0; width: 4px;
  background: var(--ca, var(--ves-blue));
  border-radius: var(--radius) 0 0 var(--radius);
}
.action-card:active { background: var(--ves-light); }
.action-card.romutus { --ca: var(--red); }
.action-card.huolto  { --ca: var(--amber); }
.action-card.varasto { --ca: var(--ves-blue); }
.ac-icon-wrap {
  width: 46px; height: 46px; border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; flex-shrink: 0;
}
.romutus .ac-icon-wrap { background: var(--red-bg); }
.huolto  .ac-icon-wrap { background: var(--amber-bg); }
.varasto .ac-icon-wrap { background: var(--ves-light); }
.ac-body { flex: 1; }
.ac-title { font-size: 16px; font-weight: 600; color: var(--ves-navy); margin-bottom: 2px; }
.ac-desc  { font-size: 13px; color: var(--ves-muted); line-height: 1.4; }
.ac-arrow { color: var(--ves-dim); font-size: 20px; flex-shrink: 0; }

/* ── FORM ── */
#screen-form { overflow-y: auto; -webkit-overflow-scrolling: touch; }
.form-scroll {
  padding: 16px 16px calc(20px + var(--safe-bottom));
  display: flex; flex-direction: column; gap: 12px;
  max-width: 560px; margin: 0 auto; width: 100%;
}
.form-toprow { display: flex; align-items: center; gap: 12px; margin-bottom: 2px; }
.back-btn {
  width: var(--tap); height: var(--tap);
  border-radius: var(--radius); border: 1px solid var(--ves-line);
  background: #fff; color: var(--ves-navy);
  font-size: 22px; cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.back-btn:active { background: var(--ves-light); }
.form-badge {
  display: inline-flex; align-items: center; gap: 5px;
  font-size: 11px; font-weight: 600; letter-spacing: 0.07em;
  text-transform: uppercase; padding: 3px 8px; border-radius: 3px; margin-bottom: 3px;
}
.badge-romutus { background: var(--red-bg);    color: var(--red); }
.badge-huolto  { background: var(--amber-bg);  color: var(--amber); }
.badge-varasto { background: var(--ves-light); color: var(--ves-blue); }
.form-title-text { font-size: 17px; font-weight: 600; color: var(--ves-navy); }

/* ── CARD ── */
.card {
  background: #fff; border: 1px solid var(--ves-line);
  border-radius: var(--radius); overflow: hidden;
  box-shadow: 0 1px 4px rgba(0,0,0,0.04);
}
.card-header {
  padding: 13px 16px 11px;
  display: flex; align-items: center; justify-content: space-between;
  border-bottom: 1px solid var(--ves-line);
  background: var(--ves-light);
}
.field-label {
  font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
  text-transform: uppercase; color: var(--ves-muted);
}
.count-pill {
  font-family: var(--mono); font-size: 12px;
  padding: 2px 9px; border-radius: 20px;
  background: var(--ves-navy); color: #fff;
}

/* ── QR CAMERA VIEWPORT ── */
#cam-viewport {
  display: none; position: relative;
  background: #000; overflow: hidden;
}
#cam-viewport.open { display: block; }

/* ZXing renders the video element — we style it */
#cam-video {
  width: 100%; display: block;
  max-height: 280px; object-fit: cover;
}

/* QR aim overlay — square frame */
.qr-overlay {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center;
  pointer-events: none;
}
.qr-frame {
  width: 200px; height: 200px;
  border: 2px solid rgba(0,174,239,0.85);
  border-radius: 8px;
  box-shadow: 0 0 0 9999px rgba(0,0,0,0.5);
  position: relative; overflow: hidden;
}
/* Corner accents */
.qr-frame::before, .qr-frame::after,
.qr-frame-b::before, .qr-frame-b::after {
  content: ''; position: absolute;
  width: 20px; height: 20px;
  border-color: var(--ves-accent); border-style: solid;
}
.qr-frame::before  { top:-2px;    left:-2px;  border-width: 3px 0 0 3px; border-radius: 6px 0 0 0; }
.qr-frame::after   { top:-2px;    right:-2px; border-width: 3px 3px 0 0; border-radius: 0 6px 0 0; }
.qr-frame-b { position: absolute; inset: 0; }
.qr-frame-b::before { bottom:-2px; left:-2px;  border-width: 0 0 3px 3px; border-radius: 0 0 0 6px; }
.qr-frame-b::after  { bottom:-2px; right:-2px; border-width: 0 3px 3px 0; border-radius: 0 0 6px 0; }
/* Scan line */
.qr-scanline {
  position: absolute; left: 6px; right: 6px; height: 2px;
  background: linear-gradient(90deg, transparent, var(--ves-accent), transparent);
  animation: scanQR 2.2s ease-in-out infinite;
}
.qr-hint {
  position: absolute; bottom: 8px; left: 0; right: 0;
  text-align: center; font-size: 12px; font-family: var(--mono);
  color: rgba(255,255,255,0.65);
}
.cam-flash {
  position: absolute; inset: 0;
  background: var(--ves-accent); opacity: 0; pointer-events: none;
  transition: opacity 0.06s;
}

/* ── SCAN BUTTON ── */
.scan-toggle-btn {
  width: 100%; min-height: 62px;
  border: none; background: var(--ves-navy); color: #fff;
  font-size: 15px; font-weight: 600; font-family: var(--sans);
  cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 12px;
  padding: 14px 16px;
}
.scan-toggle-btn.active { background: #7f1018; }
.scan-toggle-btn:active { opacity: 0.88; }
.scan-btn-icon { font-size: 24px; flex-shrink: 0; }
.scan-btn-texts { display: flex; flex-direction: column; align-items: flex-start; }
.scan-btn-sub { font-size: 12px; font-weight: 400; opacity: 0.65; margin-top: 1px; }

/* scan status rows */
.scan-status {
  display: none; padding: 10px 16px;
  align-items: center; gap: 10px; font-size: 13px;
  border-top: 1px solid var(--ves-line);
}
.scan-status.show { display: flex; }
.scan-status.loading { background: var(--ves-light); color: var(--ves-blue); }
.scan-status.ok      { background: var(--green-bg);  color: var(--green); }
.scan-status.err     { background: var(--red-bg);    color: var(--red); }
.mini-spin {
  width: 15px; height: 15px;
  border: 2px solid var(--ves-line); border-top-color: var(--ves-blue);
  border-radius: 50%; animation: spin 0.6s linear infinite; flex-shrink: 0;
}
.scan-error-banner {
  display: none; padding: 10px 14px;
  background: var(--red-bg); border-top: 1px solid #ffd0d8;
  font-size: 13px; color: var(--red); line-height: 1.5;
}
.scan-error-banner.show { display: block; }

/* ── POINT & SHOOT ── */
.ps-section { border-top: 2px solid var(--ves-line); }
.ps-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 11px 16px 9px; background: var(--ves-light);
}
.ps-badge {
  font-family: var(--mono); font-size: 11px;
  padding: 2px 8px; border-radius: 3px;
  background: var(--ves-navy); color: #fff;
}
#ps-preview-wrap {
  display: none; position: relative; background: #000; overflow: hidden;
}
#ps-preview-wrap.open { display: block; }
#ps-video { width: 100%; max-height: 260px; object-fit: cover; display: block; }
/* Same QR frame for P&S */
.ps-qr-overlay {
  position: absolute; inset: 0;
  display: flex; align-items: center; justify-content: center; pointer-events: none;
}
.ps-qr-frame {
  width: 190px; height: 190px;
  border: 2px solid rgba(0,174,239,0.85); border-radius: 8px;
  box-shadow: 0 0 0 9999px rgba(0,0,0,0.5);
  position: relative;
}
.ps-qr-frame::before, .ps-qr-frame::after,
.ps-qr-corners::before, .ps-qr-corners::after {
  content: ''; position: absolute;
  width: 20px; height: 20px; border-color: var(--ves-accent); border-style: solid;
}
.ps-qr-frame::before  { top:-2px;    left:-2px;  border-width:3px 0 0 3px; border-radius:6px 0 0 0; }
.ps-qr-frame::after   { top:-2px;    right:-2px; border-width:3px 3px 0 0; border-radius:0 6px 0 0; }
.ps-qr-corners { position: absolute; inset: 0; }
.ps-qr-corners::before { bottom:-2px; left:-2px;  border-width:0 0 3px 3px; border-radius:0 0 0 6px; }
.ps-qr-corners::after  { bottom:-2px; right:-2px; border-width:0 3px 3px 0; border-radius:0 0 6px 0; }
.ps-hint {
  position: absolute; bottom: 8px; left: 0; right: 0;
  text-align: center; font-size: 12px; font-family: var(--mono); color: rgba(255,255,255,0.65);
}
#ps-flash { position: absolute; inset:0; background:#fff; opacity:0; pointer-events:none; transition:opacity 0.05s; }
#ps-canvas { display: none; }

.ps-controls { display: flex; align-items: center; border-top: 1px solid var(--ves-line); }
.ps-open-btn {
  flex: 1; height: 56px;
  border: none; border-right: 1px solid var(--ves-line);
  background: #fff; color: var(--ves-navy);
  font-size: 14px; font-weight: 600; font-family: var(--sans);
  cursor: pointer; display: flex; align-items: center; justify-content: center; gap: 8px;
}
.ps-open-btn.active { background: var(--ves-light); color: var(--red); }
.ps-open-btn:active { background: var(--ves-light); }
.ps-capture-btn {
  width: 72px; height: 56px;
  border: none; background: var(--ves-blue); cursor: pointer;
  display: flex; align-items: center; justify-content: center; flex-shrink: 0;
}
.ps-capture-btn:disabled { background: var(--ves-line); cursor: not-allowed; }
.ps-capture-btn:not(:disabled):active { background: var(--ves-navy); transform: scale(0.95); }
.ps-capture-btn:not(:disabled) svg circle:first-child { animation: shutterPulse 1.5s ease-in-out infinite; }
@keyframes shutterPulse { 0%,100%{opacity:1} 50%{opacity:0.45} }
.ps-result {
  display: none; padding: 10px 16px;
  font-size: 13px; align-items: center; gap: 8px;
  border-top: 1px solid var(--ves-line);
}
.ps-result.ok         { display:flex; background: var(--green-bg); color: var(--green); }
.ps-result.err        { display:flex; background: var(--red-bg);   color: var(--red); }
.ps-result.processing { display:flex; background: var(--ves-light); color: var(--ves-blue); }

/* ── MANUAL ── */
.manual-row {
  display: flex; gap: 8px; padding: 10px 12px;
  border-top: 1px solid var(--ves-line); background: #FAFBFD;
}
.manual-input {
  flex: 1; height: var(--tap); padding: 0 13px;
  background: #fff; border: 1px solid var(--ves-line);
  border-radius: var(--radius); color: var(--ves-text);
  font-family: var(--mono); font-size: 14px;
  outline: none; -webkit-appearance: none;
}
.manual-input:focus { border-color: var(--ves-blue); box-shadow: 0 0 0 3px rgba(0,85,184,0.1); }
.manual-input::placeholder { color: var(--ves-dim); }
.manual-add-btn {
  height: var(--tap); padding: 0 18px;
  border: none; border-radius: var(--radius);
  background: var(--ves-blue); color: #fff;
  font-size: 20px; font-family: var(--sans); cursor: pointer; flex-shrink: 0;
}
.manual-add-btn:active { background: var(--ves-navy); }

/* ── CHIPS ── */
.chips-empty { padding: 10px 14px 14px; font-size: 13px; color: var(--ves-dim); font-style: italic; }
.chips-wrap  { display: none; padding: 10px 12px 12px; flex-wrap: wrap; gap: 7px; }
.chip {
  display: flex; align-items: center; gap: 6px; padding: 6px 10px;
  background: var(--ves-light); border: 1px solid var(--ves-line);
  border-radius: 4px; font-family: var(--mono); font-size: 13px; color: var(--ves-navy);
  animation: chipIn 0.18s cubic-bezier(.175,.885,.32,1.275) both;
}
.chip-x {
  background: none; border: none; color: var(--ves-dim);
  font-size: 16px; cursor: pointer; padding: 0;
  width: 20px; height: 20px; line-height: 1;
  display: flex; align-items: center; justify-content: center; border-radius: 3px;
}
.chip-x:active { color: var(--red); background: var(--red-bg); }

/* ── NOTES ── */
.notes-hdr { padding: 13px 16px 10px; border-bottom: 1px solid var(--ves-line); background: var(--ves-light); }
.notes-ta {
  width: 100%; padding: 12px 14px;
  background: transparent; border: none; outline: none;
  color: var(--ves-text); font-family: var(--sans); font-size: 14px;
  line-height: 1.6; resize: none; min-height: 70px; -webkit-appearance: none;
}
.notes-ta::placeholder { color: var(--ves-dim); }

/* ── SUBMIT ── */
.submit-btn {
  width: 100%; height: 54px; border: none; border-radius: var(--radius);
  font-size: 16px; font-weight: 600; font-family: var(--sans); cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 10px;
  margin-bottom: var(--safe-bottom);
  box-shadow: 0 2px 8px rgba(0,0,0,0.12);
}
.submit-btn.romutus { background: var(--red);      color: #fff; }
.submit-btn.huolto  { background: var(--amber);    color: #fff; }
.submit-btn.varasto { background: var(--ves-navy); color: #fff; }
.submit-btn:disabled { opacity: 0.3; cursor: not-allowed; box-shadow: none; }
.submit-btn:not(:disabled):active { opacity: 0.88; transform: scale(0.99); }

/* ── SUCCESS ── */
#screen-success { overflow-y: auto; }
.success-scroll {
  display: flex; align-items: center; justify-content: center;
  min-height: 100%; padding: 32px 20px calc(32px + var(--safe-bottom));
}
.success-wrap { text-align: center; max-width: 380px; width: 100%; animation: fadeUp 0.4s ease both; }
.success-circle {
  width: 68px; height: 68px; border-radius: 50%;
  margin: 0 auto 20px;
  display: flex; align-items: center; justify-content: center; font-size: 30px;
  border: 2px solid transparent;
}
.success-circle.romutus { background: var(--red-bg);    border-color: #ffc0cb; }
.success-circle.huolto  { background: var(--amber-bg);  border-color: #ffd9a0; }
.success-circle.varasto { background: var(--ves-light); border-color: var(--ves-line); }
.success-title { font-size: 21px; font-weight: 700; color: var(--ves-navy); margin-bottom: 7px; }
.success-sub   { font-size: 14px; color: var(--ves-muted); line-height: 1.5; margin-bottom: 20px; }
.success-meta {
  font-family: var(--mono); font-size: 12px;
  background: #fff; border: 1px solid var(--ves-line);
  border-radius: var(--radius); padding: 14px 16px;
  text-align: left; margin-bottom: 20px; line-height: 2.1;
}
.meta-row { display: flex; justify-content: space-between; gap: 16px; border-bottom: 1px solid var(--ves-line); }
.meta-row:last-child { border-bottom: none; }
.meta-k { color: var(--ves-muted); } .meta-v { color: var(--ves-navy); font-weight: 500; }
.new-btn {
  width: 100%; height: var(--tap);
  border: 2px solid var(--ves-navy); border-radius: var(--radius);
  background: transparent; color: var(--ves-navy);
  font-size: 15px; font-weight: 600; font-family: var(--sans); cursor: pointer;
}
.new-btn:active { background: var(--ves-light); }

/* ── LOADING ── */
.loading-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(0,45,110,0.55); backdrop-filter: blur(3px);
  z-index: 200; align-items: center; justify-content: center; flex-direction: column; gap: 14px;
}
.loading-overlay.on { display: flex; }
.spinner { width: 36px; height: 36px; border: 3px solid rgba(255,255,255,0.2); border-top-color: #fff; border-radius: 50%; animation: spin 0.7s linear infinite; }
.loading-txt { font-size: 14px; color: #fff; }

/* ── TOAST ── */
.toast {
  position: fixed; bottom: calc(20px + var(--safe-bottom));
  left: 50%; transform: translateX(-50%) translateY(80px);
  padding: 11px 18px; background: var(--ves-navy); color: #fff;
  border-radius: var(--radius); font-size: 13px;
  box-shadow: 0 4px 20px rgba(0,45,110,0.35);
  z-index: 300; opacity: 0; transition: all 0.25s ease;
  max-width: 90vw; text-align: center;
}
.toast.show { transform: translateX(-50%) translateY(0); opacity: 1; }
.toast.ok  { background: var(--green); }
.toast.err { background: var(--red); }
</style>
</head>
